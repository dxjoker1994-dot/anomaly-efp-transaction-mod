[transaction_categories]
; Define transaction categories and their display properties

[category_weapons]
name = "Weapons"
color = "255, 100, 100"
display_order = 1

[category_medical]
name = "Medical Supplies"
color = "100, 255, 100"
display_order = 2

[category_repairs]
name = "Repairs & Maintenance"
color = "255, 200, 100"
display_order = 3

[category_supplies]
name = "Supplies & Consumables"
color = "100, 150, 255"
display_order = 4

[category_misc]
name = "Miscellaneous"
color = "200, 100, 255"
display_order = 5

[category_quests]
name = "Quest Rewards"
color = "255, 255, 100"
display_order = 6

[transaction_settings]
; Log retention (0 = unlimited)
max_transactions = 0

; Date format for transactions
date_format = "%d.%m.%Y %H:%M"

; Show transaction notifications
show_notifications = true

; Notification display duration (seconds)
notification_duration = 3

; Currency display
currency_symbol = "RU"
currency_position = "after"
